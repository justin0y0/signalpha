APP_ENV=development
DEBUG=true
APP_NAME=Earnings Movement Platform
API_V1_PREFIX=/api/v1

ALPHA_VANTAGE_API_KEY=
FINANCIAL_MODELING_PREP_API_KEY=
POLYGON_API_KEY=
FRED_API_KEY=
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
SEC_USER_AGENT=earnings-platform/1.0 your-email@example.com

DATABASE_URL=postgresql+psycopg://earnings:earnings@postgres:5432/earnings
REDIS_URL=redis://redis:6379/0

MODEL_DIR=/app/artifacts
DATA_DIR=/app/data
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
SCHEDULER_TIMEZONE=America/New_York
DEFAULT_CALENDAR_LOOKAHEAD_DAYS=14
PREDICTION_CONFIDENCE_WARNING_THRESHOLD=0.7
FEATURE_COMPLETENESS_WARNING_THRESHOLD=0.8
